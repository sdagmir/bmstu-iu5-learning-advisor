# ═══════════════════════════════════════════════════════════════════════════
# РС ИТО — переменные окружения
# Скопируй в .env и заполни значения, помеченные ← ЗАПОЛНИТЬ
# ═══════════════════════════════════════════════════════════════════════════

# ── БД (Postgres на сервере) ──────────────────────────────────────────────
# Формат: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# БД и юзер уже созданы: rs_ito / rs_ito
# ⚠ ПРОД (docker-compose.prod.yml): host = host.docker.internal — backend
# в bridge-сети, БД на хосте. extra_hosts уже прописаны в compose.
# ⚠ ЛОКАЛЬНО (docker-compose.local.yml): host = postgres (имя сервиса compose).
DATABASE_URL=postgresql+asyncpg://rs_ito:rs_ito@localhost:5432/rs_ito

# ── Аутентификация ────────────────────────────────────────────────────────
# Секрет для JWT. Минимум 32 символа. Сгенерируй: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=                                    # ← ЗАПОЛНИТЬ (64 hex символа)
JWT_ACCESS_TOKEN_TTL=1800                          # 30 минут
JWT_REFRESH_TOKEN_TTL=2592000                      # 30 дней

# ── LLM (OpenRouter) ─────────────────────────────────────────────────────
# Ключ: https://openrouter.ai/keys
LLM_API_KEY=                                       # ← ЗАПОЛНИТЬ (sk-or-v1-...)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash                  # дешёвая модель с function calling

# ── Qdrant (на сервере, коллекция создаётся автоматически) ────────────────
# ⚠ ПРОД: http://host.docker.internal:6333 (Qdrant на хосте)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rs_ito_docs

# ── Эмбеддинги ───────────────────────────────────────────────────────────
# Модель для dense-векторов. Используется через тот же OpenRouter API key.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Приложение ────────────────────────────────────────────────────────────
APP_PORT=8010
# ⚠ ПРОД: DEBUG=false (отключает /docs, /openapi.json)
DEBUG=true
# CORS_ORIGINS — JSON-список разрешённых origin для фронта
# ⚠ ПРОД: ["https://rsito.твой-домен.ru"]  (без слэша в конце!)
CORS_ORIGINS=["http://localhost:3000"]

# ── Демо-аккаунт для защиты диплома ───────────────────────────────────────
# Если включён, при старте создаётся пользователь с фиксированным паролем
# и появляется endpoint POST /auth/demo-login (без пароля). Кнопка «Демо
# для комиссии» на странице логина дёргает этот endpoint.
DEMO_ACCOUNT_ENABLED=true
DEMO_ACCOUNT_EMAIL=demo@rsito.student
DEMO_ACCOUNT_PASSWORD=                             # ← ЗАПОЛНИТЬ (любая строка ≥8 симв.)
